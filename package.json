{
  "name": "vzla-finder",
  "version": "0.2.0",
  "type": "module",
  "description": "Agregador solidario de registros de desaparecidos (terremoto Venezuela 2026)",
  "scripts": {
    "demo": "node --experimental-sqlite --import tsx test/demo.ts",
    "demo:cache": "node --experimental-sqlite --import tsx test/cache.ts",
    "test": "npm run test:normalize && npm run test:dedup && npm run test:reconcile && npm run test:search && npm run test:adapters && npm run test:runner && npm run test:server && npm run demo && npm run demo:cache",
    "test:normalize": "node --experimental-sqlite --import tsx test/normalize.ts",
    "test:dedup": "node --experimental-sqlite --import tsx test/dedup.ts",
    "test:reconcile": "node --experimental-sqlite --import tsx test/reconcile.ts",
    "test:search": "node --experimental-sqlite --import tsx test/search.ts",
    "test:adapters": "node --experimental-sqlite --import tsx test/adapters.ts",
    "test:runner": "node --experimental-sqlite --import tsx test/runner.ts",
    "test:server": "node --experimental-sqlite --import tsx test/server.ts",
    "ingest": "node --experimental-sqlite --import tsx src/cli.ts ingest",
    "watch": "node --experimental-sqlite --import tsx src/cli.ts watch",
    "serve": "node --experimental-sqlite --import tsx src/server.ts",
    "search": "node --experimental-sqlite --import tsx src/cli.ts search",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cheerio": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.22.0",
    "typescript": "^5.6.0"
  }
}
